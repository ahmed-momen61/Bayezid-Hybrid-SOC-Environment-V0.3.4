generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  extensions = [vector]
}

model Alert {
  id                 String   @id @default(uuid())
  sourceIp           String
  targetServer       String
  eventType          String
  attempts           Int      @default(1)
  
  // Basic Analysis
  severity           String?
  threatType         String?
  recommendedAction  String?
  
  status             String   @default("NEW")
  
  confidenceType     String   @default("PROBABILISTIC")
  
  // Advanced AI & CTI Analysis
  cvssScore          String?
  cweId              String?
  mitreTactic        String?
  mitreTechnique     String?
  killChainPhase     String?
  predictedSteps     String?
  businessContinuity String?
  osintData          Json?    
  
  messages           ChatMessage[]
  
  createdAt          DateTime @default(now())
  chats     IncidentChat[]
  playbookDetails    String?
  embedding          Unsupported("vector(768)")?
}

model Playbook {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  actions     Json
  createdAt   DateTime @default(now())
}

model RedSwarmLog {
  id              Int      @id @default(autoincrement())
  targetIp        String
  agentName       String   // Scout, Breacher, Phantom, Chameleon
  assignedTask    String   @db.Text
  executedCommand String?  @db.Text
  executionOutput String?  @db.Text 
  isSuccess       Boolean? 
  createdAt       DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(uuid())
  content   String   @db.Text
  sender    String   
  role      String   
  
  alertId   String
  alert     Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}

model SystemConfig {
  id        String   @id @default("current") 
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model IncidentChat {
  id        String   @id @default(uuid())
  alertId   String
  sender    String   
  message   String
  createdAt DateTime @default(now())
  
  alert     Alert    @relation(fields: [alertId], references: [id])
}