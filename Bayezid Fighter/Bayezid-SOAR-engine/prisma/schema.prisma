generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Alert {
  id                 String   @id @default(uuid())
  sourceIp           String
  targetServer       String
  eventType          String
  attempts           Int      @default(1)
  
  // Basic Analysis
  severity           String?
  threatType         String?
  recommendedAction  String?
  status             String   @default("NEW")
  
  // Advanced AI & CTI Analysis
  cvssScore          String?
  cweId              String?
  mitreTactic        String?
  mitreTechnique     String?
  killChainPhase     String?
  predictedSteps     String?
  businessContinuity String?
  osintData          Json?    
  
  createdAt          DateTime @default(now())
}

model Playbook {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  actions     Json
  createdAt   DateTime @default(now())
}